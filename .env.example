# This is a *project-level* reference of all env vars used in the monorepo.
# Create:
# - `backend/.env` from `backend/.env.example`
# - `frontend/.env` from `frontend/.env.example`
#
# Backend (Node/Express)
NODE_ENV=development
PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/roundtechsquare
JWT_SECRET=replace_me_with_a_long_random_secret
JWT_EXPIRES_IN=7d
#
# Frontend (Expo)
# Use `http://10.0.2.2:5000` for Android emulator if backend runs on your machine.
EXPO_PUBLIC_API_BASE_URL=http://localhost:5000

